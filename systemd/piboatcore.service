[Unit]
Description=PiBoatCore boat telemetry service
Wants=network-online.target NetworkManager-wait-online.service
After=network-online.target NetworkManager-wait-online.service
StartLimitIntervalSec=0

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/piboatcore
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/piboatcore/.venv/bin/python -m pi_boat_core --config /etc/piboatcore/config.toml
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
