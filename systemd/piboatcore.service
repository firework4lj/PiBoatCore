[Unit]
Description=PiBoatCore boat telemetry service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/piboatcore
ExecStart=/opt/piboatcore/.venv/bin/python -m pi_boat_core --config /etc/piboatcore/config.toml
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
